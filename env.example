"use client";

import { useMemo, useState } from "react";
import { Car, Calculator, Plus, Save, Trash2 } from "lucide-react";
import { calculateTradeIn, Comparable, formatCurrency, VehicleInput } from "@/lib/calcul-reprise";
import { supabase } from "@/lib/supabase";

const defaultVehicle: VehicleInput = {
  brand: "Volkswagen",
  model: "Tiguan",
  trim: "R-Line Exclusive",
  year: 2022,
  mileage: 62000,
  energy: "Diesel",
  gearbox: "DSG",
  clientPrice: 26000,
  bodyScore: 8,
  mechanicalScore: 8,
  tireScore: 7,
  serviceScore: 8,
  prepCost: 900,
  warrantyCost: 650,
  targetMargin: 2500,
  negotiationRisk: 700,
  holdingCost: 400,
  notes: "Véhicule propre, entretien suivi, préparation esthétique légère."
};

const defaultComparables: Comparable[] = [
  { source: "La Centrale", title: "Tiguan R-Line 2022 DSG", year: 2022, mileage: 59000, price: 29990, days: 38 },
  { source: "Leboncoin", title: "Tiguan R-Line Exclusive", year: 2021, mileage: 71000, price: 28490, days: 52 },
  { source: "AutoScout24", title: "Tiguan R-Line 2.0 TDI", year: 2022, mileage: 64000, price: 29200, days: 44 }
];

type ComparableWithId = Comparable & { id: number };

export default function RepriseForm() {
  const [vehicle, setVehicle] = useState<VehicleInput>(defaultVehicle);
  const [comparables, setComparables] = useState<ComparableWithId[]>(
    defaultComparables.map((item, index) => ({ ...item, id: index + 1 }))
  );
  const [saveMessage, setSaveMessage] = useState("");

  const result = useMemo(() => calculateTradeIn(vehicle, comparables), [vehicle, comparables]);

  const updateVehicle = <K extends keyof VehicleInput>(field: K, value: VehicleInput[K]) => {
    setVehicle((previous) => ({ ...previous, [field]: value }));
  };

  const updateComparable = <K extends keyof Comparable>(id: number, field: K, value: Comparable[K]) => {
    setComparables((previous) =>
      previous.map((item) => (item.id === id ? { ...item, [field]: value } : item))
    );
  };

  const addComparable = () => {
    setComparables((previous) => [
      ...previous,
      {
        id: Date.now(),
        source: "Source",
        title: `${vehicle.brand} ${vehicle.model}`,
        year: vehicle.year,
        mileage: vehicle.mileage,
        price: 0,
        days: 30
      }
    ]);
  };

  const removeComparable = (id: number) => {
    setComparables((previous) => previous.filter((item) => item.id !== id));
  };

  const saveCase = async () => {
    setSaveMessage("");
    if (!supabase) {
      setSaveMessage("Supabase n'est pas encore configuré. Le calcul fonctionne, mais la sauvegarde est désactivée.");
      return;
    }

    const { error } = await supabase.from("trade_in_cases").insert({
      brand: vehicle.brand,
      model: vehicle.model,
      trim: vehicle.trim,
      year: vehicle.year,
      mileage: vehicle.mileage,
      energy: vehicle.energy,
      gearbox: vehicle.gearbox,
      client_price: vehicle.clientPrice,
      vehicle,
      comparables,
      result,
      status: "draft"
    });

    setSaveMessage(error ? `Erreur sauvegarde : ${error.message}` : "Dossier sauvegardé.");
  };

  return (
    <main className="min-h-screen bg-slate-50 p-4 md:p-8 text-slate-900">
      <div className="mx-auto max-w-7xl space-y-6">
        <header className="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <div>
            <div className="flex items-center gap-2">
              <Car className="h-8 w-8" />
              <h1 className="text-3xl font-bold tracking-tight">ReprisePilot VO</h1>
            </div>
            <p className="mt-2 text-slate-600">Cotation interne de reprise véhicule avec comparables marché et marge cible.</p>
          </div>
          <button onClick={saveCase} className="inline-flex items-center justify-center gap-2 rounded-xl bg-slate-900 px-4 py-3 font-semibold text-white shadow-sm hover:bg-slate-800">
            <Save className="h-4 w-4" /> Sauvegarder le dossier
          </button>
        </header>

        {saveMessage && <div className="rounded-xl border bg-white p-3 text-sm text-slate-700">{saveMessage}</div>}

        <section className="grid grid-cols-1 gap-4 lg:grid-cols-4">
          <div className="rounded-2xl bg-white p-5 shadow-sm lg:col-span-1">
            <div className="flex items-center gap-2 font-semibold"><Calculator className="h-5 w-5" /> Résultat</div>
            <div className="mt-4 text-4xl font-bold">{formatCurrency(result.idealTradeIn)}</div>
            <p className="text-sm text-slate-500">Prix de reprise conseillé</p>
            <div className="mt-4 grid grid-cols-2 gap-2 text-sm">
              <div className="rounded-xl bg-slate-100 p-3"><div className="text-slate-500">Mini</div><b>{formatCurrency(result.minTradeIn)}</b></div>
              <div className="rounded-xl bg-slate-100 p-3"><div className="text-slate-500">Max</div><b>{formatCurrency(result.maxTradeIn)}</b></div>
            </div>
            <div className="mt-4 rounded-xl bg-slate-100 p-3 text-sm">
              <div className="flex justify-between"><span>Risque</span><b>{result.riskLabel}</b></div>
              <div className="mt-2 h-3 overflow-hidden rounded-full bg-slate-200">
                <div className="h-full bg-slate-900" style={{ width: `${result.riskScore}%` }} />
              </div>
            </div>
          </div>

          <div className="rounded-2xl bg-white p-5 shadow-sm lg:col-span-3">
            <h2 className="mb-4 text-xl font-bold">Véhicule</h2>
            <div className="grid grid-cols-1 gap-3 md:grid-cols-4">
              <TextInput label="Marque" value={vehicle.brand} onChange={(value) => updateVehicle("brand", value)} />
              <TextInput label="Modèle" value={vehicle.model} onChange={(value) => updateVehicle("model", value)} />
              <TextInput label="Finition" value={vehicle.trim} onChange={(value) => updateVehicle("trim", value)} />
              <NumberInput label="Année" value={vehicle.year} onChange={(value) => updateVehicle("year", value)} />
              <NumberInput label="Kilométrage" value={vehicle.mileage} onChange={(value) => updateVehicle("mileage", value)} />
              <TextInput label="Énergie" value={vehicle.energy} onChange={(value) => updateVehicle("energy", value)} />
              <TextInput label="Boîte" value={vehicle.gearbox} onChange={(value) => updateVehicle("gearbox", value)} />
              <NumberInput label="Prix souhaité client" value={vehicle.clientPrice} onChange={(value) => updateVehicle("clientPrice", value)} />
            </div>

            <h2 className="mb-4 mt-6 text-xl font-bold">État et coûts</h2>
            <div className="grid grid-cols-1 gap-3 md:grid-cols-4">
              <NumberInput label="Carrosserie /10" value={vehicle.bodyScore} onChange={(value) => updateVehicle("bodyScore", value)} />
              <NumberInput label="Mécanique /10" value={vehicle.mechanicalScore} onChange={(value) => updateVehicle("mechanicalScore", value)} />
              <NumberInput label="Pneus /10" value={vehicle.tireScore} onChange={(value) => updateVehicle("tireScore", value)} />
              <NumberInput label="Entretien /10" value={vehicle.serviceScore} onChange={(value) => updateVehicle("serviceScore", value)} />
              <NumberInput label="Frais VO" value={vehicle.prepCost} onChange={(value) => updateVehicle("prepCost", value)} />
              <NumberInput label="Garantie" value={vehicle.warrantyCost} onChange={(value) => updateVehicle("warrantyCost", value)} />
              <NumberInput label="Marge cible" value={vehicle.targetMargin} onChange={(value) => updateVehicle("targetMargin", value)} />
              <NumberInput label="Risque négo" value={vehicle.negotiationRisk} onChange={(value) => updateVehicle("negotiationRisk", value)} />
              <NumberInput label="Immobilisation" value={vehicle.holdingCost} onChange={(value) => updateVehicle("holdingCost", value)} />
            </div>
          </div>
        </section>

        <section className="rounded-2xl bg-white p-5 shadow-sm">
          <div className="mb-4 flex items-center justify-between gap-3">
            <h2 className="text-xl font-bold">Comparables marché</h2>
            <button onClick={addComparable} className="inline-flex items-center gap-2 rounded-xl border px-3 py-2 text-sm font-semibold hover:bg-slate-50">
              <Plus className="h-4 w-4" /> Ajouter
            </button>
          </div>
          <div className="space-y-3">
            {comparables.map((item) => (
              <div key={item.id} className="grid grid-cols-1 gap-2 rounded-xl border p-3 md:grid-cols-7">
                <TextInput label="Source" value={item.source} onChange={(value) => updateComparable(item.id, "source", value)} />
                <div className="md:col-span-2"><TextInput label="Annonce" value={item.title} onChange={(value) => updateComparable(item.id, "title", value)} /></div>
                <NumberInput label="Année" value={item.year} onChange={(value) => updateComparable(item.id, "year", value)} />
                <NumberInput label="Km" value={item.mileage} onChange={(value) => updateComparable(item.id, "mileage", value)} />
                <NumberInput label="Prix" value={item.price} onChange={(value) => updateComparable(item.id, "price", value)} />
                <div className="flex items-end gap-2">
                  <NumberInput label="Jours" value={item.days} onChange={(value) => updateComparable(item.id, "days", value)} />
                  <button onClick={() => removeComparable(item.id)} className="mb-0.5 rounded-lg border p-2 hover:bg-slate-50" aria-label="Supprimer">
                    <Trash2 className="h-4 w-4" />
                  </button>
                </div>
              </div>
            ))}
          </div>
        </section>

        <section className="grid grid-cols-1 gap-4 md:grid-cols-2">
          <SummaryCard title="Analyse marché">
            <Line label="Prix moyen affiché" value={formatCurrency(result.avgMarketPrice)} />
            <Line label="Prix vente rapide" value={formatCurrency(result.quickSalePrice)} />
            <Line label="Délai moyen" value={`${result.avgDays} jours`} />
            <Line label="Décote rapidité" value={`${Math.round(result.fastSaleDiscount * 100)} %`} />
          </SummaryCard>
          <SummaryCard title="Justification reprise">
            <Line label="Frais VO" value={formatCurrency(vehicle.prepCost)} />
            <Line label="Garantie" value={formatCurrency(vehicle.warrantyCost)} />
            <Line label="Marge cible" value={formatCurrency(vehicle.targetMargin)} />
            <Line label="Pénalité état" value={formatCurrency(result.conditionPenalty)} />
            <Line label="Écart demande client" value={formatCurrency(result.clientGap)} />
          </SummaryCard>
        </section>
      </div>
    </main>
  );
}

function TextInput({ label, value, onChange }: { label: string; value: string; onChange: (value: string) => void }) {
  return (
    <label className="block text-sm font-medium text-slate-700">
      {label}
      <input value={value} onChange={(event) => onChange(event.target.value)} className="mt-1 w-full rounded-xl border px-3 py-2 outline-none focus:ring-2 focus:ring-slate-300" />
    </label>
  );
}

function NumberInput({ label, value, onChange }: { label: string; value: number; onChange: (value: number) => void }) {
  return (
    <label className="block w-full text-sm font-medium text-slate-700">
      {label}
      <input type="number" value={value} onChange={(event) => onChange(Number(event.target.value))} className="mt-1 w-full rounded-xl border px-3 py-2 outline-none focus:ring-2 focus:ring-slate-300" />
    </label>
  );
}

function SummaryCard({ title, children }: { title: string; children: React.ReactNode }) {
  return (
    <div className="rounded-2xl bg-white p-5 shadow-sm">
      <h2 className="mb-3 text-xl font-bold">{title}</h2>
      <div className="space-y-2 text-sm">{children}</div>
    </div>
  );
}

function Line({ label, value }: { label: string; value: string }) {
  return <div className="flex justify-between gap-4 rounded-xl bg-slate-100 px-3 py-2"><span>{label}</span><b>{value}</b></div>;
}
